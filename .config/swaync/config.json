{
    "$schema": "/etc/xdg/swaync/configschema.json",
    "positionX": "right",
    "positionY": "top",
    "cssPriority": "user",
    "control-center-width": 360,
    "fit-to-screen": false,

    "notification-window-width": 340,
    "notification-icon-size": 40,
    "notification-body-image-height": 500,
    "notification-body-image-width": 500,
    "notification-inline-replies": true,
    "notification-2fa-action": false,
  
    "timeout": 3,
    "timeout-low": 2,
    "timeout-critical": 6,
    
    "keyboard-shortcuts": true,
    "image-visibility": "when-available",
    "transition-time": 200,
    "hide-on-clear": false,
    "hide-on-action": false,
    "script-fail-notify": true,

    "widgets": [
      "label",
      "buttons-grid",
      "mpris",
      "volume",
      "title",
      "notifications",
      "dnd"
    ],
   
    "widget-config": {
    	"label": {
    	    "max-lines": 1,
      	    "text": " 󰣇 Arch Linux Btw "
    	},	    
    	"title": {
      	    "text": "Notifications",
            "clear-all-button": true,
      	    "button-text": " 󰎟 "
        },
        "volume": {
            "device": "default",
            "label": "",
	    "expand-button-label": " ",
      	    "collapse-button-label": " ",
      	    "show-per-app": true,
            "show-per-app-icon": true,
            "slider": true
        },

        "dnd": {
            "text": "Do not disturb"
        },

        "mpris": {
            "image-size": 60,
            "image-radius": 10,
	    "width": 100
        },

        "buttons-grid": {
            "actions": [
                {
                    "label": " Inhibitor",
                    "type": "toggle",
                    "command": "bash -c $HOME/.config/waybar/scripts/inhibit.sh",
                    "update-command": "sh -c $HOME/.config/waybar/scripts/update_inhibit.sh"
                },
		{
		    "label": "󰕾",
          	    "command": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
          	    "type": "toggle"
                },
                {
                    "label": "",
                    "type": "toggle",
                    "command": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
                    "update-command": "sh -c $HOME/.config/swaync/scripts/update_mic.sh"
                },
                {
                    "label": " Tasks",
                    "command": "hyprctl dispatch exec kitty -- -e btop ; swaync-client -cp"
                },
                {
                    "label": "",
                    "command": "hyprctl dispatch exec nwg-look ; swaync-client -cp"
                },
                {
                    "label": "",
                    "command": "swaync-client -cp ; sleep 1 ; hyprshot -zm region"
                }
            ]
        }
    }
  }
